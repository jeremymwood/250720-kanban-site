DATABASE_URL=postgresql://user:password@localhost:5432/ishi
PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_long_random_secret
# Optional auth/session tuning
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_DAYS=30
# Optional graceful shutdown timeout in ms
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
# Comma-separated exact origin allowlist (no trailing slash, no wildcard)
# Example: https://app.ishikanban.com,https://staging.ishikanban.com
CORS_ORIGIN=http://localhost:5173

# Optional: enforce verification regardless of NODE_ENV
ENFORCE_EMAIL_VERIFICATION=false

# Optional: seed-user bypass while verification rollout is in progress
SEED_VERIFICATION_BYPASS_USERNAMES=alex,niko,priya,marcus,claire,owen,maya
SEED_VERIFICATION_BYPASS_EMAILS=

# Twilio Verify Email (required when ENFORCE_EMAIL_VERIFICATION=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Distributed rate limiting (required in production)
REDIS_URL=

