        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "express": "^5.2.1",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.6.1",
        "jsonwebtoken": "^9.0.3",
        "rate-limiter-flexible": "^5.0.5",
        "twilio": "^5.12.1",
